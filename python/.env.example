# Required
GEMINI_API_KEY=your-gemini-api-key-here
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Optional (defaults shown)
DATABASE_URL=sqlite:///./fair_view.db
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOWED_ORIGINS=*
AUDIO_DIR=./audio
# Python Backend
